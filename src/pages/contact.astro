---
export const prerender = true;
import Base from '../layouts/Base.astro';

const contactEmail = 'contact@distancefrom.co';
const defaultMailto = `mailto:${contactEmail}?subject=DistanceFrom.co%20Inquiry`;
const topicLinks = [
  {
    label: 'Bug report',
    href: `mailto:${contactEmail}?subject=Bug%20Report%20for%20DistanceFrom.co`,
  },
  {
    label: 'Data correction',
    href: `mailto:${contactEmail}?subject=Data%20Correction%20for%20DistanceFrom.co`,
  },
  {
    label: 'Feature idea',
    href: `mailto:${contactEmail}?subject=Feature%20Idea%20for%20DistanceFrom.co`,
  },
  {
    label: 'Business inquiry',
    href: `mailto:${contactEmail}?subject=Business%20Inquiry%20for%20DistanceFrom.co`,
  },
];
---
<Base
  title="Contact Us — DistanceFrom.co"
  description="Email the DistanceFrom.co team with questions, bug reports, data corrections, or partnership inquiries."
>
  <div class="contact-page">
    <h1 class="animate-in">Contact Us</h1>
    <p class="contact-intro animate-in animate-in-delay-1">
      Questions, bug reports, data corrections, and partnership inquiries are best handled by email.
    </p>

    <section class="card--flat email-hero animate-in animate-in-delay-2">
      <div class="email-copy">
        <p class="eyebrow">Email-first support</p>
        <h2>Send us an email directly</h2>
        <p class="email-summary">
          We removed the form to keep support simpler and more reliable. Email gives you a copy of your
          message, makes follow-up easier, and helps us handle detailed issues with more context.
        </p>
      </div>

      <div class="email-actions">
        <a href={defaultMailto} class="email-cta">Email {contactEmail}</a>
        <a href={`mailto:${contactEmail}`} class="email-address">{contactEmail}</a>
      </div>
    </section>

    <section class="topic-section animate-in animate-in-delay-2">
      <p class="topic-label">Start with a ready-made subject line:</p>
      <div class="topic-links">
        {topicLinks.map((topic) => (
          <a href={topic.href} class="topic-chip">{topic.label}</a>
        ))}
      </div>
    </section>

    <div class="contact-grid animate-in animate-in-delay-2">
      <div class="card--flat info-card">
        <div class="info-icon" style="--icon-bg: var(--color-success-bg); --icon-color: var(--color-success);">
          <svg class="icon-svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3>Response Time</h3>
        <p>We usually reply within 24-48 hours on business days.</p>
      </div>

      <div class="card--flat info-card">
        <div class="info-icon" style="--icon-bg: var(--color-info-bg); --icon-color: var(--color-info);">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3>Best Way To Reach Us</h3>
        <p>Use the email above for support, feedback, partnerships, or press requests.</p>
      </div>

      <div class="card--flat info-card">
        <div class="info-icon" style="--icon-bg: rgba(245, 158, 11, 0.14); --icon-color: #d97706;">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 16h.01"/><path d="M12 8v4"/><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
        </div>
        <h3>For Faster Help</h3>
        <p>Include the two cities, what looked wrong, and a screenshot if you are reporting a route or data issue.</p>
      </div>
    </div>
  </div>
</Base>

<style>
  .contact-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-top: var(--space-lg);
  }

  .contact-intro {
    color: var(--text-secondary);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xl);
    font-size: var(--text-lg);
    max-width: 760px;
  }

  .email-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.9fr);
    gap: var(--space-xl);
    align-items: center;
    padding: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .eyebrow {
    margin: 0 0 var(--space-sm);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    font-weight: 700;
  }

  .email-copy h2 {
    margin-bottom: var(--space-sm);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.1;
  }

  .email-summary {
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 60ch;
  }

  .email-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: stretch;
  }

  .email-cta,
  .email-address,
  .topic-chip {
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .email-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 20px;
    border-radius: var(--radius-md);
    background: var(--color-primary);
    color: var(--text-on-primary);
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(2, 132, 199, 0.22);
  }

  .email-cta:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
  }

  .email-address {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-weight: 600;
  }

  .email-address:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .topic-section {
    margin-bottom: var(--space-xl);
  }

  .topic-label {
    margin-bottom: var(--space-sm);
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .topic-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .topic-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .topic-chip:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-md);
    align-items: stretch;
  }

  .info-card {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    min-height: 100%;
  }

  .info-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--icon-bg);
    color: var(--icon-color);
  }

  .info-card h3 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
  }

  .info-card p {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .email-hero {
      grid-template-columns: 1fr;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
