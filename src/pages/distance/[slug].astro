---
export const prerender = false; // SSR for long-tail, will add getStaticPaths for top pairs later

import Base from '../../layouts/Base.astro';
import DistanceResult from '../../components/DistanceResult.astro';
import NaturalDescription from '../../components/NaturalDescription.astro';
import Map from '../../components/Map.astro';
import TravelComparison from '../../components/TravelComparison.astro';
import MidwayStops from '../../components/MidwayStops.astro';
import QuickFacts from '../../components/QuickFacts.astro';
import RelatedDistances from '../../components/RelatedDistances.astro';
import DidYouKnow from '../../components/DidYouKnow.astro';
import DataSources from '../../components/DataSources.astro';
import DualSearchBox from '../../components/DualSearchBox.astro';

import citiesData from '../../data/cities.json';
import fuelPricesJson from '../../data/fuel-prices.json';

import { haversine } from '../../utils/haversine';
import { bearing } from '../../utils/bearing';
import { driveEstimate } from '../../utils/drive-estimate';
import type { OsrmRouteEntry } from '../../utils/drive-estimate';
import { flightEstimate } from '../../utils/flight-estimate';
import { findMidwayStops } from '../../utils/midway-stops';
import { tripCost, setFuelPrices } from '../../utils/trip-cost';
import { canonicalPairKey } from '../../utils/slug';
import { distancePageTitle, distancePageDescription, canonicalUrl, distanceJsonLd } from '../../utils/seo';
import { getCanonicalCities, getCanonicalCitySlug, getDisplayCityName } from '../../utils/city-identity';

import type { City } from '../../data/types';

// Initialize fuel prices (small, safe to keep in bundle)
setFuelPrices(fuelPricesJson as any);

const cities = citiesData as Record<string, City>;
const canonicalCities = getCanonicalCities(cities);

// Parse slug: "new-york-to-boston"
const rawSlug = Astro.params.slug ?? '';
const parts = rawSlug.replace(/\/$/, '').split('-to-');
if (parts.length !== 2) return Astro.redirect('/');
const [rawSlugA, rawSlugB] = parts;

const slugA = getCanonicalCitySlug(rawSlugA, cities);
const slugB = getCanonicalCitySlug(rawSlugB, cities);
if (!cities[slugA] || !cities[slugB]) return Astro.redirect('/');
if (slugA === slugB) {
  return Astro.redirect(`/city/${slugA}/`, 301);
}

const pairSlug = canonicalPairKey(slugA, slugB);
if (rawSlug !== pairSlug) {
  return Astro.redirect(`/distance/${pairSlug}/`, 301);
}

const cityA = cities[slugA];
const cityB = cities[slugB];
const cityALabel = getDisplayCityName(slugA, cityA, cities);
const cityBLabel = getDisplayCityName(slugB, cityB, cities);

// Fetch OSRM route data on demand from static assets (avoids bundling 17MB)
let osrmData: OsrmRouteEntry | null = null;
try {
  // canonicalPairKey puts alphabetically-first city first, which matches
  // how split-route-data.ts files data under the first city slug.
  const originCity = pairSlug.split('-to-')[0];
  const routeRes = await fetch(new URL(`/data/routes/${originCity}.json`, Astro.url));
  if (routeRes.ok) {
    const cityRoutes: Record<string, OsrmRouteEntry> = await routeRes.json();
    osrmData = cityRoutes[pairSlug] ?? null;
  }
} catch {
  // Graceful fallback — haversine estimate will be used
}

// Compute all data
const dist = haversine(cityA.lat, cityA.lng, cityB.lat, cityB.lng);
const bear = bearing(cityA.lat, cityA.lng, cityB.lat, cityB.lng);
const drive = driveEstimate(dist.km, cityA.lat, cityA.lng, cityB.lat, cityB.lng, osrmData);
const flight = flightEstimate(dist.km);
const cost = drive.drivable ? tripCost(drive.distanceKm, cityA.country, cityB.country) : null;
const stops = findMidwayStops(slugA, cityA.lat, cityA.lng, slugB, cityB.lat, cityB.lng, canonicalCities);

// Related distances
function getRelated(slug: string, city: City, excludeSlug: string) {
  const seen = new Set<string>();
  return (city.nearby ?? [])
    .map((s: string) => getCanonicalCitySlug(s, cities))
    .filter((s: string) => s !== slug && s !== excludeSlug && cities[s] && !seen.has(s) && seen.add(s))
    .slice(0, 6)
    .map((s: string) => {
      const c = cities[s];
      const d = haversine(city.lat, city.lng, c.lat, c.lng);
      return { slug: s, name: getDisplayCityName(s, c, cities), distanceMiles: d.miles };
    });
}
const relatedA = getRelated(slugA, cityA, slugB);
const relatedB = getRelated(slugB, cityB, slugA);

// SEO
const title = distancePageTitle(cityALabel, cityBLabel, dist.miles, drive.formatted, cityA.type, cityB.type);
const description = distancePageDescription(
  cityALabel, cityBLabel, dist.miles, dist.km,
  drive.formatted, flight.formatted, cost?.formatted ?? 'N/A',
);
const canonical = canonicalUrl(slugA, slugB);
// Index same-country pairs (valuable even with haversine estimates)
// and all pairs with OSRM data. Only noindex cross-country pairs without OSRM.
const sameCountry = cityA.country === cityB.country;
const robots = (drive.source === 'osrm' || sameCountry) ? 'index, follow' : 'noindex, follow';
const pageHeading = `${cityALabel} to ${cityBLabel}: Road Trip Guide & Distance`;

// Enhanced JSON-LD with FAQ and BreadcrumbList
const jsonLd = distanceJsonLd(cityALabel, cityBLabel, slugA, dist.miles, dist.km, canonical);

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://distancefrom.co/" },
    { "@type": "ListItem", "position": 2, "name": `${cityALabel} Distances`, "item": `https://distancefrom.co/city/${slugA}/` },
    { "@type": "ListItem", "position": 3, "name": `${cityALabel} to ${cityBLabel}` },
  ]
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What's the best route from ${cityALabel} to ${cityBLabel}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The most popular route from ${cityALabel} to ${cityBLabel} covers ${drive.drivable ? drive.distanceMiles : dist.miles} miles and takes ${drive.formatted}. Plan ahead with our road trip guide featuring top stops and fuel cost estimates.`
      }
    },
    {
      "@type": "Question",
      "name": `How far is ${cityALabel} from ${cityBLabel} by car?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${drive.drivable ? `By car, ${cityALabel} to ${cityBLabel} is ${drive.distanceMiles} miles (${drive.distanceKm} km) and takes about ${drive.formatted}.` : `Driving from ${cityALabel} to ${cityBLabel} may not be feasible. The straight-line distance is ${dist.miles} miles (${dist.km} km).`}${cost ? ` Estimated fuel cost is ${cost.formatted}.` : ''}`
      }
    },
    ...(drive.drivable ? [{
      "@type": "Question",
      "name": `Where should I stop between ${cityALabel} and ${cityBLabel}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Great question! The halfway point between ${cityALabel} and ${cityBLabel} is perfect for a break. Explore our curated list of top stops, hidden gems, and scenic viewpoints along the route.`
      }
    }] : []),
    {
      "@type": "Question",
      "name": `Is it better to fly or drive from ${cityALabel} to ${cityBLabel}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Compare your options: Driving takes ${drive.formatted}${cost ? ` and costs about ${cost.formatted} in fuel` : ''}. Flying takes approximately ${flight.formatted}. Use our comparison tool to decide which works best for you!`
      }
    }
  ]
};
---
<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd} robots={robots}>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href={`/city/${slugA}/`}>{cityALabel}</a></li>
      <li aria-current="page">{cityALabel} to {cityBLabel}</li>
    </ol>
  </nav>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />

  <h1 class="page-title animate-in">{pageHeading}</h1>

  <div class="search-compact animate-in animate-in-delay-1">
    <DualSearchBox />
  </div>

  <DistanceResult
    straightLineMiles={dist.miles} straightLineKm={dist.km}
    drivingMiles={drive.distanceMiles} drivingKm={drive.distanceKm}
    driveTime={drive.formatted} driveSource={drive.source} drivable={drive.drivable}
    flightTime={flight.formatted} noDirectFlight={flight.noDirectFlight}
    bearingDeg={bear.degrees} bearingDir={bear.direction}
    fuelCost={cost?.formatted ?? 'N/A'}
  />

  <NaturalDescription
    cityA={{ name: cityALabel, state: cityA.state, countryName: cityA.countryName, type: cityA.type }}
    cityB={{ name: cityBLabel, state: cityB.state, countryName: cityB.countryName, type: cityB.type }}
    straightLineMiles={dist.miles} straightLineKm={dist.km}
    drivable={drive.drivable} driveMiles={drive.distanceMiles}
    driveTime={drive.formatted} flightTime={flight.formatted}
    bearingDir={bear.direction}
  />

  <Map lat1={cityA.lat} lng1={cityA.lng} label1={cityALabel}
       lat2={cityB.lat} lng2={cityB.lng} label2={cityBLabel} />

  <TravelComparison
    cityA={cityALabel} cityB={cityBLabel}
    drivable={drive.drivable} driveTime={drive.formatted}
    driveMiles={drive.distanceMiles} driveMinutes={drive.durationMin}
    fuelCost={cost?.formatted ?? 'N/A'} flightTime={flight.formatted}
    noDirectFlight={flight.noDirectFlight} straightLineKm={dist.km}
  />

  <MidwayStops cityA={cityALabel} cityB={cityBLabel} cityASlug={slugA} cityBSlug={slugB} stops={stops} />

  <QuickFacts cityA={{ name: cityALabel, lat: cityA.lat, lng: cityA.lng, timezone: cityA.timezone, elevation: cityA.elevation }}
              cityB={{ name: cityBLabel, lat: cityB.lat, lng: cityB.lng, timezone: cityB.timezone, elevation: cityB.elevation }} />

  <RelatedDistances
    cityAName={cityALabel} cityBName={cityBLabel}
    cityASlug={slugA} cityBSlug={slugB}
    fromA={relatedA} fromB={relatedB}
  />

  <div class="explore-section animate-in">
    <a href={`/city/${slugB}/`} class="explore-link">
      <svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="M2 12h20"/><path d="m15 5 7 7-7 7"/></svg>
      Explore more routes from {cityBLabel}
    </a>
  </div>

  <DidYouKnow cityA={cityALabel} cityB={cityBLabel} straightLineMiles={dist.miles} straightLineKm={dist.km} />

  <DataSources driveSource={drive.source} />
</Base>

<style>
  .breadcrumb {
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }
  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--text-muted);
    flex-wrap: wrap;
  }
  .breadcrumb li + li::before {
    content: '/';
    margin-right: 6px;
    color: var(--border);
  }
  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--duration-fast);
  }
  .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb [aria-current="page"] {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .page-title {
    margin-top: var(--space-sm);
  }

  .search-compact {
    max-width: 640px;
  }

  .explore-section {
    margin: var(--space-lg) 0;
  }
  .explore-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-glass);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    transition: all var(--duration-fast) var(--ease-out);
  }
  .explore-link:hover {
    color: var(--color-primary);
    background: var(--bg-card);
    border-color: var(--color-primary-light);
  }
</style>
