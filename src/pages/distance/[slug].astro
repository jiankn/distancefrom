---
export const prerender = false; // SSR for long-tail, will add getStaticPaths for top pairs later

import Base from '../../layouts/Base.astro';
import DistanceResult from '../../components/DistanceResult.astro';
import NaturalDescription from '../../components/NaturalDescription.astro';
import Map from '../../components/Map.astro';
import TravelComparison from '../../components/TravelComparison.astro';
import MidwayStops from '../../components/MidwayStops.astro';
import QuickFacts from '../../components/QuickFacts.astro';
import RelatedDistances from '../../components/RelatedDistances.astro';
import DidYouKnow from '../../components/DidYouKnow.astro';
import DataSources from '../../components/DataSources.astro';
import DualSearchBox from '../../components/DualSearchBox.astro';

import citiesData from '../../data/cities.json';
import routeDataJson from '../../data/route-data.json';
import fuelPricesJson from '../../data/fuel-prices.json';

import { haversine } from '../../utils/haversine';
import { bearing } from '../../utils/bearing';
import { driveEstimate, setRouteData } from '../../utils/drive-estimate';
import { flightEstimate } from '../../utils/flight-estimate';
import { findMidwayStops } from '../../utils/midway-stops';
import { tripCost, setFuelPrices } from '../../utils/trip-cost';
import { isCanonicalOrder, canonicalPairKey } from '../../utils/slug';
import { distancePageTitle, distancePageDescription, canonicalUrl, distanceJsonLd } from '../../utils/seo';

import type { City } from '../../data/types';

// Initialize data
setRouteData(routeDataJson as any);
setFuelPrices(fuelPricesJson as any);

const cities = citiesData as Record<string, City>;

// Parse slug: "new-york-to-boston"
const rawSlug = Astro.params.slug ?? '';
const parts = rawSlug.replace(/\/$/, '').split('-to-');
if (parts.length !== 2) return Astro.redirect('/');
const [slugA, slugB] = parts;

// Canonical redirect: if not in alphabetical order, 301 to canonical
if (!isCanonicalOrder(slugA, slugB)) {
  return Astro.redirect(`/distance/${slugB}-to-${slugA}/`, 301);
}

const cityA = cities[slugA];
const cityB = cities[slugB];
if (!cityA || !cityB) return Astro.redirect('/');

// Compute all data
const dist = haversine(cityA.lat, cityA.lng, cityB.lat, cityB.lng);
const bear = bearing(cityA.lat, cityA.lng, cityB.lat, cityB.lng);
const drive = driveEstimate(slugA, slugB, dist.km, cityA.lat, cityA.lng, cityB.lat, cityB.lng);
const flight = flightEstimate(dist.km);
const cost = drive.drivable ? tripCost(drive.distanceKm, cityA.country, cityB.country) : null;
const stops = findMidwayStops(slugA, cityA.lat, cityA.lng, slugB, cityB.lat, cityB.lng, cities);

// Related distances
function getRelated(slug: string, city: City, excludeSlug: string) {
  return (city.nearby ?? [])
    .filter((s: string) => s !== excludeSlug && cities[s])
    .slice(0, 6)
    .map((s: string) => {
      const c = cities[s];
      const d = haversine(city.lat, city.lng, c.lat, c.lng);
      return { slug: s, name: c.name, distanceMiles: d.miles };
    });
}
const relatedA = getRelated(slugA, cityA, slugB);
const relatedB = getRelated(slugB, cityB, slugA);

// SEO
const title = distancePageTitle(cityA.name, cityB.name, dist.miles, drive.formatted, cityA.type, cityB.type);
const description = distancePageDescription(
  cityA.name, cityB.name, dist.miles, dist.km,
  drive.formatted, flight.formatted, cost?.formatted ?? 'N/A',
);
const canonical = canonicalUrl(slugA, slugB);

// Enhanced JSON-LD with FAQ and BreadcrumbList
const jsonLd = distanceJsonLd(cityA.name, cityB.name, dist.miles, dist.km, canonical);

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://distancefrom.co/" },
    { "@type": "ListItem", "position": 2, "name": `${cityA.name} Distances`, "item": `https://distancefrom.co/city/${slugA}/` },
    { "@type": "ListItem", "position": 3, "name": `${cityA.name} to ${cityB.name}` },
  ]
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `How far is ${cityA.name} from ${cityB.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The straight-line distance from ${cityA.name} to ${cityB.name} is ${dist.miles} miles (${dist.km} km).${drive.drivable ? ` The driving distance is ${drive.distanceMiles} miles (${drive.distanceKm} km), taking approximately ${drive.formatted}.` : ''}`
      }
    },
    ...(drive.drivable ? [{
      "@type": "Question",
      "name": `How long does it take to drive from ${cityA.name} to ${cityB.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The drive from ${cityA.name} to ${cityB.name} takes approximately ${drive.formatted}, covering ${drive.distanceMiles} miles.${cost ? ` Estimated fuel cost: ${cost.formatted}.` : ''}`
      }
    }] : []),
    {
      "@type": "Question",
      "name": `How long is the flight from ${cityA.name} to ${cityB.name}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `A flight from ${cityA.name} to ${cityB.name} takes approximately ${flight.formatted}.${flight.noDirectFlight ? ' Note: direct flights may not be available for this route.' : ''}`
      }
    }
  ]
};
---
<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><a href={`/city/${slugA}/`}>{cityA.name}</a></li>
      <li aria-current="page">{cityA.name} to {cityB.name}</li>
    </ol>
  </nav>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />

  <h1 class="page-title animate-in">Distance from {cityA.name} to {cityB.name}</h1>

  <div class="search-compact animate-in animate-in-delay-1">
    <DualSearchBox />
  </div>

  <DistanceResult
    straightLineMiles={dist.miles} straightLineKm={dist.km}
    drivingMiles={drive.distanceMiles} drivingKm={drive.distanceKm}
    driveTime={drive.formatted} driveSource={drive.source} drivable={drive.drivable}
    flightTime={flight.formatted} noDirectFlight={flight.noDirectFlight}
    bearingDeg={bear.degrees} bearingDir={bear.direction}
    fuelCost={cost?.formatted ?? 'N/A'}
  />

  <NaturalDescription
    cityA={{ name: cityA.name, state: cityA.state, countryName: cityA.countryName, type: cityA.type }}
    cityB={{ name: cityB.name, state: cityB.state, countryName: cityB.countryName, type: cityB.type }}
    straightLineMiles={dist.miles} straightLineKm={dist.km}
    drivable={drive.drivable} driveMiles={drive.distanceMiles}
    driveTime={drive.formatted} flightTime={flight.formatted}
    bearingDir={bear.direction}
  />

  <Map lat1={cityA.lat} lng1={cityA.lng} label1={cityA.name}
       lat2={cityB.lat} lng2={cityB.lng} label2={cityB.name} />

  <TravelComparison
    cityA={cityA.name} cityB={cityB.name}
    drivable={drive.drivable} driveTime={drive.formatted}
    driveMiles={drive.distanceMiles} driveMinutes={drive.durationMin}
    fuelCost={cost?.formatted ?? 'N/A'} flightTime={flight.formatted}
    noDirectFlight={flight.noDirectFlight} straightLineKm={dist.km}
  />

  <MidwayStops cityA={cityA.name} cityB={cityB.name} cityASlug={slugA} cityBSlug={slugB} stops={stops} />

  <QuickFacts cityA={{ name: cityA.name, lat: cityA.lat, lng: cityA.lng, timezone: cityA.timezone, elevation: cityA.elevation }}
              cityB={{ name: cityB.name, lat: cityB.lat, lng: cityB.lng, timezone: cityB.timezone, elevation: cityB.elevation }} />

  <RelatedDistances
    cityAName={cityA.name} cityBName={cityB.name}
    cityASlug={slugA} cityBSlug={slugB}
    fromA={relatedA} fromB={relatedB}
  />

  <div class="reverse-section animate-in">
    <a href={`/distance/${slugB}-to-${slugA}/`} class="reverse-link">
      <svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="m7 16 4 4 4-4"/><path d="M11 20V4"/></svg>
      Reverse: {cityB.name} to {cityA.name}
    </a>
  </div>

  <DidYouKnow cityA={cityA.name} cityB={cityB.name} straightLineMiles={dist.miles} straightLineKm={dist.km} />

  <DataSources driveSource={drive.source} />
</Base>

<style>
  .breadcrumb {
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }
  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--text-muted);
    flex-wrap: wrap;
  }
  .breadcrumb li + li::before {
    content: '/';
    margin-right: 6px;
    color: var(--border);
  }
  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--duration-fast);
  }
  .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb [aria-current="page"] {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .page-title {
    margin-top: var(--space-sm);
  }

  .search-compact {
    max-width: 640px;
  }

  .reverse-section {
    margin: var(--space-lg) 0;
  }
  .reverse-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-glass);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    transition: all var(--duration-fast) var(--ease-out);
  }
  .reverse-link:hover {
    color: var(--color-primary);
    background: var(--bg-card);
    border-color: var(--color-primary-light);
  }
</style>
