---
export const prerender = true;

import Base from '../layouts/Base.astro';
import DualSearchBox from '../components/DualSearchBox.astro';
import citiesData from '../data/cities.json';
import { haversine } from '../utils/haversine';
import { canonicalPairKey } from '../utils/slug';

// Top popular pairs for homepage
const popularPairs = [
  ['new-york', 'boston'], ['los-angeles', 'san-francisco'], ['chicago', 'detroit'],
  ['dallas', 'houston'], ['new-york', 'washington-dc'], ['miami', 'orlando'],
  ['london', 'paris'], ['seattle', 'portland'], ['las-vegas', 'grand-canyon'],
  ['san-francisco', 'los-angeles'], ['new-york', 'philadelphia'], ['denver', 'aspen'],
  ['los-angeles', 'las-vegas'], ['atlanta', 'nashville'], ['denver', 'yellowstone'],
  ['madrid', 'barcelona'], ['berlin', 'amsterdam'], ['sydney', 'melbourne'],
  ['tokyo', 'kyoto'], ['toronto', 'niagara-falls-ca'],
];

const cities = citiesData as Record<string, any>;
const routes = popularPairs
  .map(([a, b]) => {
    const cA = cities[a]; const cB = cities[b];
    if (!cA || !cB) return null;
    const d = haversine(cA.lat, cA.lng, cB.lat, cB.lng);
    const key = canonicalPairKey(a, b);
    return { from: cA.name, to: cB.name, miles: d.miles, km: d.km, href: `/distance/${key}/` };
  })
  .filter(Boolean)
  .slice(0, 20);

// Stats
const totalCities = Object.keys(cities).length;
const totalPairs = (totalCities * (totalCities - 1)) / 2;

// Featured cities for browse section
const featuredCities = ['new-york', 'london', 'tokyo', 'paris', 'sydney', 'dubai', 'grand-canyon', 'los-angeles', 'rome', 'banff', 'barcelona', 'queenstown-nz']
  .filter(s => cities[s])
  .map(s => ({ slug: s, name: cities[s].name, country: cities[s].countryName }));
---
<Base title="Distance Calculator — How Far Between Cities | DistanceFrom.co" description="Calculate the distance between any two cities worldwide. Get driving distance, drive time, flight time, fuel cost, and best stops along the way.">

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title animate-in">How Far Between Cities?</h1>
      <p class="hero-subtitle animate-in animate-in-delay-1">Get real driving distances, flight times, fuel costs & best stops — all in one place.</p>
      <div class="hero-search animate-in animate-in-delay-2">
        <DualSearchBox />
      </div>
    </div>

    <!-- Trust Stats -->
    <div class="hero-stats animate-in animate-in-delay-3">
      <div class="stat-item">
        <span class="stat-value">{totalCities}+</span>
        <span class="stat-label">Cities</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-value">{totalPairs.toLocaleString()}+</span>
        <span class="stat-label">City Pairs</span>
      </div>
      <div class="stat-sep"></div>
      <div class="stat-item">
        <span class="stat-value">Free</span>
        <span class="stat-label">Always</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features animate-in animate-in-delay-3">
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon" style="--icon-bg: var(--color-success-bg); --icon-color: var(--color-success);">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-2-2.2-3.3C13 5.6 11.7 5 10 5H5c-1.3 0-2.5.7-3.2 1.7L.5 9H2l1 3h1"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
        </div>
        <h3>Real Driving Routes</h3>
        <p>Actual road distances from OSRM, not just straight lines.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="--icon-bg: rgba(59, 130, 246, 0.1); --icon-color: #3b82f6;">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
        </div>
        <h3>Flight Time Estimates</h3>
        <p>Compare flying vs. driving to make smarter travel decisions.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="--icon-bg: rgba(245, 158, 11, 0.1); --icon-color: #f59e0b;">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3>Fuel Cost Calculator</h3>
        <p>Estimate trip costs with regional fuel prices.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon" style="--icon-bg: rgba(239, 68, 68, 0.1); --icon-color: #ef4444;">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M18 6 7 17l-5-5"/><path d="m22 10-7.5 7.5L13 16"/></svg>
        </div>
        <h3>Best Stops Along the Way</h3>
        <p>Discover recommended stops between any two cities.</p>
      </div>
    </div>
  </section>

  <!-- Popular Routes -->
  <section class="popular animate-in">
    <h2 class="section-title">
      <svg class="icon-svg" viewBox="0 0 24 24" style="color: var(--color-primary);"><path d="m3 11 18-5v12L3 13v-2z"/></svg>
      Popular Routes
    </h2>
    <div class="routes-grid">
      {routes.map(r => r && (
        <a href={r.href} class="route-card">
          <div class="route-cities">
            <span class="route-from">{r.from}</span>
            <svg class="route-arrow icon-svg--sm" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            <span class="route-to">{r.to}</span>
          </div>
          <span class="route-dist">{r.miles} mi</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse Cities -->
  {featuredCities.length > 0 && (
    <section class="browse animate-in">
      <h2 class="section-title">
        <svg class="icon-svg" viewBox="0 0 24 24" style="color: var(--color-primary);"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Browse by City
      </h2>
      <div class="cities-grid">
        {featuredCities.map(c => (
          <a href={`/city/${c.slug}/`} class="city-card">
            <span class="city-card-name">{c.name}</span>
            <span class="city-card-country">{c.country}</span>
          </a>
        ))}
      </div>
    </section>
  )}

</Base>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: var(--space-3xl) 0 var(--space-xl);
  }
  .hero-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    margin-top: var(--space-sm);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 560px;
    margin-inline: auto;
  }
  .hero-search {
    max-width: 640px;
    margin: var(--space-xl) auto 0;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
    padding: var(--space-lg) var(--space-xl);
    background: var(--bg-card);
    border: var(--glass-border);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    box-shadow: var(--shadow-sm);
    max-width: 480px;
    margin-inline: auto;
  }
  .stat-item { text-align: center; }
  .stat-value {
    display: block;
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
  }
  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .stat-sep {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* Features */
  .features { margin-top: var(--space-2xl); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }
  .feature-card {
    background: var(--bg-card);
    border: var(--glass-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    text-align: center;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px; height: 48px;
    border-radius: var(--radius-md);
    background: var(--icon-bg);
    color: var(--icon-color);
    margin-bottom: var(--space-sm);
  }
  .feature-card h3 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .feature-card p {
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Popular Routes */
  .popular { margin-top: var(--space-2xl); }
  .section-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-lg);
  }

  .routes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-sm);
  }
  .route-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px var(--space-md);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    transition: all var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .route-card:hover {
    border-color: var(--color-primary-light);
    background: var(--bg-card-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
    color: var(--text-primary);
  }
  .route-cities {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    font-weight: 500;
  }
  .route-arrow { color: var(--color-primary); width: 14px; height: 14px; }
  .route-dist {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 500;
    white-space: nowrap;
  }

  /* Browse Cities */
  .browse { margin-top: var(--space-2xl); }
  .cities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-sm);
  }
  .city-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    transition: all var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .city-card:hover {
    border-color: var(--color-primary-light);
    background: var(--bg-card-hover);
    transform: translateY(-1px);
    color: var(--text-primary);
  }
  .city-card-name { font-weight: 600; font-size: var(--text-sm); }
  .city-card-country { font-size: var(--text-xs); color: var(--text-muted); margin-top: 2px; }

  @media (max-width: 768px) {
    .hero { padding: var(--space-xl) 0 var(--space-md); }
    .hero-title { font-size: var(--text-2xl); }
    .hero-subtitle { font-size: var(--text-base); }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .hero-stats { gap: var(--space-md); padding: var(--space-md); }
    .stat-value { font-size: var(--text-xl); }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: var(--text-xl); }
    .features-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: var(--space-sm); }
  }
</style>
