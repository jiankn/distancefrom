    color: var(--text-primary);
  }
  .content h3 {
    margin-top: var(--space-md);
    font-size: var(--text-base);
    color: var(--text-primary);
  }
  .content p { margin-top: var(--space-sm); color: var(--text-secondary); }
  .content ul {
    margin-top: var(--space-sm);
    padding-left: var(--space-xl);
    color: var(--text-secondary);
  }
