---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import DualSearchBox from '../../components/DualSearchBox.astro';
import citiesData from '../../data/cities.json';
import { haversine } from '../../utils/haversine';
import { canonicalPairKey } from '../../utils/slug';
import { cityHubUrl } from '../../utils/seo';
import { getCanonicalCitySlug, getCanonicalCitySlugs, getDisplayCityName } from '../../utils/city-identity';
import { getIndexableCitySlugs, isIndexableCitySlug, isIndexableDistancePair } from '../../utils/indexability';
import type { City } from '../../data/types';

const cities = citiesData as Record<string, City>;
const rawSlug = Astro.params.city ?? '';
const slug = getCanonicalCitySlug(rawSlug, cities);
if (!cities[slug]) return Astro.redirect('/');
if (rawSlug !== slug) return Astro.redirect(`/city/${slug}/`, 301);

const city = cities[slug];
const cityLabel = getDisplayCityName(slug, city, cities);
const canonical = cityHubUrl(slug);
const indexableCitySlugs = new Set(getIndexableCitySlugs(cities));
const browseCitySlugs = new Set(getCanonicalCitySlugs(cities).filter((candidate) => indexableCitySlugs.has(candidate)));
const robots = isIndexableCitySlug(slug, cities) ? 'index, follow' : 'noindex, follow';
const MAX_POPULAR = 12;
const MAX_DOMESTIC_PER_SECTION = 24;
const MAX_INTL_COUNTRIES = 8;
const MAX_INTL_PER_COUNTRY = 8;

// All distances from this city, sorted by distance
const distances = Object.entries(cities)
  .filter(([s]) => s !== slug && browseCitySlugs.has(s))
  .map(([s, c]) => {
    const d = haversine(city.lat, city.lng, c.lat, c.lng);
    const key = canonicalPairKey(slug, s);
    return {
      slug: s,
      name: getDisplayCityName(s, c, cities),
      country: c.countryName,
      countryCode: c.country,
      miles: d.miles,
      km: d.km,
      href: `/distance/${key}/`,
      type: c.type,
      population: c.population,
    };
  })
  .filter((d) => isIndexableDistancePair({
    slugA: slug,
    slugB: d.slug,
    cities,
    hasRouteData: false,
    distanceMiles: d.miles,
  }))
  .sort((a, b) => a.miles - b.miles);

const isNP = city.type === 'national-park';
const titlePrefix = isNP ? `Distances from ${cityLabel} to Nearby Cities` : `Distances from ${cityLabel} to Major Cities & Destinations`;
const title = titlePrefix;
const description = city.description
  ? `${city.description}. Find distances from ${cityLabel} to ${distances.length}+ destinations worldwide.`
  : `Find the distance from ${cityLabel} to any city worldwide. Driving distance, flight time, and more.`;

// Stats
const nearest = distances[0];
const farthest = distances[distances.length - 1];

// Popular routes: top 10 by population product heuristic
const popular = [...distances]
  .sort((a, b) => (b.population ?? 0) - (a.population ?? 0))
  .slice(0, MAX_POPULAR);

// Domestic vs international
const domestic = distances.filter(d => d.countryCode === city.country);
const international = distances.filter(d => d.countryCode !== city.country);
const nearbyCount = domestic.filter(d => d.miles <= 200).length;
const mediumCount = domestic.filter(d => d.miles > 200 && d.miles <= 1000).length;
const farawayCount = domestic.filter(d => d.miles > 1000).length;

// Group domestic by range
const nearby = domestic.filter(d => d.miles <= 200).slice(0, MAX_DOMESTIC_PER_SECTION);
const medium = domestic.filter(d => d.miles > 200 && d.miles <= 1000).slice(0, MAX_DOMESTIC_PER_SECTION);
const faraway = domestic.filter(d => d.miles > 1000).slice(0, MAX_DOMESTIC_PER_SECTION);

// Group international by country
const intlByCountry: Record<string, typeof distances> = {};
for (const d of international) {
  if (!intlByCountry[d.country]) intlByCountry[d.country] = [];
  intlByCountry[d.country].push(d);
}
const intlCountries = Object.entries(intlByCountry).sort((a, b) => {
  const minA = Math.min(...a[1].map(d => d.miles));
  const minB = Math.min(...b[1].map(d => d.miles));
  return minA - minB;
}).slice(0, MAX_INTL_COUNTRIES);

const citySummary = [
  `${cityLabel} has ${distances.length} indexable distance guides on DistanceFrom.co.`,
  nearest ? `The nearest listed destination is ${nearest.name} at ${nearest.miles} miles (${nearest.km} km).` : '',
  farthest ? `The farthest listed destination is ${farthest.name} at ${farthest.miles} miles (${farthest.km} km).` : '',
  domestic.length > 0 ? `${domestic.length} routes stay within ${city.countryName}; ${nearbyCount} are under 200 miles, ${mediumCount} are 200 to 1,000 miles, and ${farawayCount} are over 1,000 miles.` : '',
  international.length > 0 ? `${international.length} routes connect ${cityLabel} with destinations abroad, grouped by country below for faster scanning.` : '',
].filter(Boolean).join(' ');

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://distancefrom.co/" },
    { "@type": "ListItem", "position": 2, "name": `${cityLabel} Distances`, "item": canonical },
  ]
};

const cityPageLd = [
  breadcrumbLd,
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: canonical,
    about: {
      '@type': city.type === 'national-park' ? 'TouristAttraction' : 'Place',
      name: cityLabel,
      address: {
        '@type': 'PostalAddress',
        addressCountry: city.countryName,
        ...(city.state ? { addressRegion: city.state } : {}),
      },
    },
    mainEntity: popular.slice(0, 10).map((d) => ({
      '@type': 'WebPage',
      name: `${cityLabel} to ${d.name}`,
      url: `${d.href.startsWith('/') ? 'https://distancefrom.co' : ''}${d.href}`,
    })),
  },
];
---
<Base title={title} description={description} canonical={canonical} jsonLd={cityPageLd} robots={robots}>
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li aria-current="page">{cityLabel}</li>
    </ol>
  </nav>

  <div class="city-hero animate-in">
    <h1>{title}</h1>
    {city.description && <p class="city-desc">{city.description}</p>}
    <div class="city-meta">
      <span class="city-meta-item">
        <svg class="icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 11.5 7.3 11.8a1 1 0 0 0 1.4 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
        {city.countryName}
      </span>
      <span class="city-meta-item">
        <svg class="icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        {city.timezone}
      </span>
      <span class="city-meta-item">
        <svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><circle cx="12" cy="12" r="10"/></svg>
        {distances.length} destinations
      </span>
    </div>
  </div>

  <!-- Stats -->
  {nearest && farthest && (
    <div class="stats-bar animate-in animate-in-delay-1">
      <div class="stat-chip">Nearest: <a href={nearest.href}>{nearest.name}</a> ({nearest.miles} mi)</div>
      <div class="stat-chip">Farthest: <a href={farthest.href}>{farthest.name}</a> ({farthest.miles} mi)</div>
    </div>
  )}

  {distances.length > 0 && (
    <section class="city-summary animate-in animate-in-delay-1">
      <h2>Distance Planning from {cityLabel}</h2>
      <p>{citySummary}</p>
    </section>
  )}

  <div class="search-compact animate-in animate-in-delay-1">
    <DualSearchBox />
  </div>

  <!-- Popular Routes -->
  {popular.length > 0 && (
    <section class="distance-group animate-in animate-in-delay-2">
      <h2 class="group-title">
        <span class="group-badge popular">Popular</span>
        Most Popular Routes
      </h2>
      <div class="card--flat distance-list">
        {popular.map(d => (
          <a href={d.href} class="city-row">
            <div class="city-row-info">
              <span class="city-row-name">{d.name}</span>
              <span class="city-row-country">{d.country}</span>
            </div>
            <span class="city-row-dist">{d.miles} mi <small>({d.km} km)</small></span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Domestic distances -->
  {nearby.length > 0 && (
    <section class="distance-group animate-in">
      <h2 class="group-title">
        <span class="group-badge nearby">Nearby</span>
        Under 200 miles
      </h2>
      <div class="card--flat distance-list">
        {nearby.map(d => (
          <a href={d.href} class="city-row">
            <div class="city-row-info">
              <span class="city-row-name">{d.name}</span>
              <span class="city-row-country">{d.country}</span>
            </div>
            <span class="city-row-dist">{d.miles} mi <small>({d.km} km)</small></span>
          </a>
        ))}
      </div>
    </section>
  )}

  {medium.length > 0 && (
    <section class="distance-group animate-in">
      <h2 class="group-title">
        <span class="group-badge medium">Medium</span>
        200 – 1,000 miles
      </h2>
      <div class="card--flat distance-list">
        {medium.map(d => (
          <a href={d.href} class="city-row">
            <div class="city-row-info">
              <span class="city-row-name">{d.name}</span>
              <span class="city-row-country">{d.country}</span>
            </div>
            <span class="city-row-dist">{d.miles} mi <small>({d.km} km)</small></span>
          </a>
        ))}
      </div>
    </section>
  )}

  {faraway.length > 0 && (
    <section class="distance-group animate-in">
      <h2 class="group-title">
        <span class="group-badge faraway">Far Away</span>
        Over 1,000 miles
      </h2>
      <div class="card--flat distance-list">
        {faraway.map(d => (
          <a href={d.href} class="city-row">
            <div class="city-row-info">
              <span class="city-row-name">{d.name}</span>
              <span class="city-row-country">{d.country}</span>
            </div>
            <span class="city-row-dist">{d.miles} mi <small>({d.km} km)</small></span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- International by country -->
  {intlCountries.length > 0 && (
    <section class="distance-group animate-in">
      <h2 class="group-title">
        <span class="group-badge intl">International</span>
        Destinations Abroad
      </h2>
      {intlCountries.map(([countryName, dests]) => (
        <details class="country-group">
          <summary class="country-header">{countryName} <span class="country-count">({dests.length})</span></summary>
          <div class="card--flat distance-list">
            {dests.slice(0, MAX_INTL_PER_COUNTRY).map(d => (
              <a href={d.href} class="city-row">
                <div class="city-row-info">
                  <span class="city-row-name">{d.name}</span>
                </div>
                <span class="city-row-dist">{d.miles} mi <small>({d.km} km)</small></span>
              </a>
            ))}
          </div>
        </details>
      ))}
    </section>
  )}
</Base>

<style>
  .breadcrumb {
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }
  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .breadcrumb li + li::before {
    content: '/';
    margin-right: 6px;
    color: var(--border);
  }
  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--duration-fast);
  }
  .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb [aria-current="page"] {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .city-hero { margin-top: var(--space-sm); }
  .city-hero h1 { margin-bottom: var(--space-sm); }
  .city-desc {
    font-size: var(--text-sm); color: var(--text-secondary);
    line-height: 1.6; margin-bottom: var(--space-sm);
  }

  .stats-bar {
    display: flex; gap: var(--space-md); flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .stat-chip {
    font-size: var(--text-xs); color: var(--text-muted);
    padding: 4px 12px; background: var(--bg-glass);
    border: 1px solid var(--border-light); border-radius: var(--radius-full);
  }
  .stat-chip a { color: var(--color-primary); font-weight: 500; }

  .city-summary {
    margin: var(--space-lg) 0;
    padding: var(--space-lg);
    background: var(--bg-glass);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .city-summary h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
  }
  .city-summary p {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .group-badge.popular { background: rgba(249,115,22,0.1); color: var(--color-cta); }
  .group-badge.intl { background: rgba(139,92,246,0.1); color: #8b5cf6; }

  .country-group { margin-top: var(--space-sm); }
  .country-header {
    cursor: pointer; font-size: var(--text-sm); font-weight: 500;
    color: var(--text-secondary); padding: var(--space-sm) 0;
    list-style: none;
  }
  .country-header::-webkit-details-marker { display: none; }
  .country-header::before { content: '▸ '; color: var(--color-primary); }
  details[open] > .country-header::before { content: '▾ '; }
  .country-count { color: var(--text-muted); font-weight: 400; }

  .city-meta {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .city-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .city-meta-item .icon-svg--sm { color: var(--color-primary); }

  .search-compact {
    max-width: 640px;
  }

  .distance-group {
    margin-top: var(--space-xl);
  }

  .group-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }
  .group-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .group-badge.nearby { background: var(--color-success-bg); color: var(--color-success); }
  .group-badge.medium { background: var(--color-info-bg); color: var(--color-info); }
  .group-badge.faraway { background: var(--color-warning-bg); color: var(--color-warning); }

  .distance-list {
    padding: 0;
    overflow: hidden;
  }

  .city-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px var(--space-lg);
    color: var(--text-primary);
    transition: background var(--duration-fast);
    cursor: pointer;
  }
  .city-row:hover {
    background: rgba(255, 255, 255, 0.3);
    color: var(--text-primary);
  }
  .city-row + .city-row { border-top: 1px solid var(--border); }

  .city-row-info { display: flex; align-items: center; gap: var(--space-sm); }
  .city-row-name { font-size: var(--text-sm); font-weight: 500; }
  .city-row-country { font-size: var(--text-xs); color: var(--text-muted); }

  .city-row-dist {
    color: var(--text-muted);
    font-size: var(--text-sm);
    white-space: nowrap;
    font-weight: 500;
  }
  .city-row-dist small {
    font-weight: 400;
    font-size: var(--text-xs);
  }
</style>
