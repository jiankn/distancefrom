---
interface Props {
  cityA: string;
  cityB: string;
  straightLineMiles: number;
  straightLineKm: number;
}
const { cityA, cityB, straightLineMiles, straightLineKm } = Astro.props;

const walkHours = Math.round(straightLineMiles / 3);
const bikeHours = Math.round(straightLineMiles / 12);
const equatorTimes = Math.round((40075 / straightLineKm) * 10) / 10;

const facts: string[] = [];
if (walkHours > 0) facts.push(`At walking speed (3 mph), it would take about ${walkHours} hours of non-stop walking`);
if (bikeHours > 0) facts.push(`By bicycle at 12 mph, the journey would take roughly ${bikeHours} hours`);
if (equatorTimes > 1 && equatorTimes < 1000) facts.push(`You could travel this distance about ${equatorTimes} times to circle the Earth's equator`);
if (equatorTimes <= 1) facts.push(`This distance is ${Math.round((straightLineKm / 40075) * 100)}% of the way around the Earth's equator`);
---
{facts.length > 0 && (
  <section class="dyk-section animate-in">
    <div class="dyk-icon">
      <svg class="icon-svg" viewBox="0 0 24 24"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
    </div>
    <div class="dyk-content">
      <h3>Did You Know?</h3>
      <ul>
        {facts.map(f => <li>{f}</li>)}
      </ul>
    </div>
  </section>
)}

<style>
  .dyk-section {
    display: flex; gap: var(--space-md); align-items: flex-start;
    margin: var(--space-lg) 0; padding: var(--space-lg);
    background: var(--color-info-bg); border: 1px solid rgba(2,132,199,0.15);
    border-radius: var(--radius-md);
  }
  .dyk-icon { color: var(--color-primary); flex-shrink: 0; margin-top: 2px; }
  .dyk-content h3 {
    font-size: var(--text-sm); font-weight: 600;
    color: var(--color-primary); margin-bottom: var(--space-sm);
  }
  .dyk-content ul { list-style: none; padding: 0; margin: 0; }
  .dyk-content li {
    font-size: var(--text-sm); color: var(--text-secondary);
    line-height: 1.6; padding: 2px 0;
  }
  .dyk-content li + li { margin-top: 4px; }
</style>
