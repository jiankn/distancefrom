---
interface Stop {
  slug: string;
  name: string;
  country: string;
  distanceFromA_km: number;
}
interface Props {
  cityA: string;
  cityB: string;
  cityASlug: string;
  cityBSlug: string;
  stops: Stop[];
}
const { cityA, cityB, cityASlug, cityBSlug, stops } = Astro.props;
const KM_TO_MILES = 0.621371;

function pairUrl(a: string, b: string) {
  return `/distance/${a < b ? a + '-to-' + b : b + '-to-' + a}/`;
}
---
{stops.length > 0 && (
  <section class="card--flat midway-section animate-in animate-in-delay-2">
    <div class="midway-header">
      <div class="section-icon" style="--icon-bg: rgba(239, 68, 68, 0.1); --icon-color: #ef4444;">
        <svg class="icon-svg" viewBox="0 0 24 24"><path d="M18 6 7 17l-5-5"/><path d="m22 10-7.5 7.5L13 16"/></svg>
      </div>
      <h2>Best Stops Between {cityA} & {cityB}</h2>
    </div>
    <ul class="stops-list">
      {stops.map((s, i) => (
        <li class="stop-item">
          <div class="stop-index">{i + 1}</div>
          <div class="stop-content">
            <div class="stop-name">
              <a href={`/city/${s.slug}/`}>{s.name}</a>
              <span class="stop-country">{s.country}</span>
            </div>
            <div class="stop-links">
              <a href={pairUrl(cityASlug, s.slug)} class="stop-route">{cityA} → {s.name}</a>
              <a href={pairUrl(s.slug, cityBSlug)} class="stop-route">{s.name} → {cityB}</a>
            </div>
          </div>
          <span class="stop-dist">{Math.round(s.distanceFromA_km * KM_TO_MILES)} mi</span>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .midway-section { margin: var(--space-lg) 0; padding: 0; overflow: hidden; }

  .midway-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }
  .midway-header h2 {
    font-size: var(--text-lg);
    color: var(--text-primary);
  }

  .section-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    background: var(--icon-bg);
    color: var(--icon-color);
    flex-shrink: 0;
  }

  .stops-list { list-style: none; }

  .stop-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    transition: background var(--duration-fast);
  }
  .stop-item:hover { background: rgba(255, 255, 255, 0.3); }
  .stop-item + .stop-item { border-top: 1px solid var(--border); }

  .stop-index {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--radius-full);
    background: var(--color-info-bg);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    flex-shrink: 0;
  }

  .stop-content { flex: 1; min-width: 0; }
  .stop-name { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; }
  .stop-name a { font-weight: 500; color: var(--text-primary); }
  .stop-name a:hover { color: var(--color-primary); }
  .stop-country { font-size: var(--text-sm); color: var(--text-muted); }

  .stop-links {
    display: flex; gap: var(--space-md);
    margin-top: 4px;
  }
  .stop-route {
    font-size: var(--text-xs);
    color: var(--text-muted);
    transition: color var(--duration-fast);
  }
  .stop-route:hover { color: var(--color-primary); }

  .stop-dist {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .stop-item { padding: var(--space-sm) var(--space-md); }
    .stop-links { flex-direction: column; gap: 2px; }
  }
</style>
