---
// Dual city search with autocomplete — upgraded UI
import citiesData from '../data/cities.json';
import { getCanonicalCitySlugs, getDisplayCityName } from '../utils/city-identity';

const cityRecord = citiesData as Record<string, any>;
const cities = getCanonicalCitySlugs(cityRecord).map((slug) => {
  const city = cityRecord[slug];
  return {
    slug,
    name: getDisplayCityName(slug, city, cityRecord),
    searchName: city.name,
    country: city.countryName,
    state: city.state,
  };
});
---
<form class="search-box animate-in" action="/distance/" method="get" id="search-form" role="search" aria-label="Distance search">
  <div class="search-inputs">
    <div class="input-group">
      <label for="from-input" class="sr-only">From city</label>
      <div class="input-wrapper">
        <svg class="input-icon icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 11.5 7.3 11.8a1 1 0 0 0 1.4 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
        <input type="text" id="from-input" name="from" placeholder="From city..." autocomplete="off" required aria-label="Origin city" />
      </div>
      <ul class="suggestions" id="from-suggestions" role="listbox" aria-label="City suggestions"></ul>
    </div>

    <button type="button" class="swap-btn" id="swap-btn" aria-label="Swap cities" tabindex="0">
      <svg class="icon-svg" viewBox="0 0 24 24"><path d="m7 16 4 4 4-4"/><path d="M11 20V4"/></svg>
    </button>

    <div class="input-group">
      <label for="to-input" class="sr-only">To city</label>
      <div class="input-wrapper">
        <svg class="input-icon icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 11.5 7.3 11.8a1 1 0 0 0 1.4 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
        <input type="text" id="to-input" name="to" placeholder="To city..." autocomplete="off" required aria-label="Destination city" />
      </div>
      <ul class="suggestions" id="to-suggestions" role="listbox" aria-label="City suggestions"></ul>
    </div>
  </div>

  <button type="submit" class="submit-btn">
    <svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="M2 12h20"/><path d="m15 5 7 7-7 7"/></svg>
    Calculate Distance
  </button>
</form>

<style>
  .search-box {
    margin: var(--space-xl) 0;
    position: relative;
    z-index: 100;
  }

  .search-inputs {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .input-group {
    flex: 1;
    min-width: 200px;
    position: relative;
  }
  .input-group:focus-within {
    z-index: 20;
  }

  .input-wrapper {
    position: relative;
  }

  .input-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-primary);
    pointer-events: none;
    width: 16px;
    height: 16px;
  }

  .input-group input {
    width: 100%;
    padding: 14px 16px 14px 40px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--text-base);
    font-family: var(--font-sans);
    outline: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-sm);
    transition: all var(--duration-fast) var(--ease-out);
  }
  .input-group input::placeholder {
    color: var(--text-muted);
  }
  .input-group input:focus {
    border-color: var(--color-primary);
    background: var(--bg-glass-strong);
    box-shadow: var(--shadow-glow);
  }

  .swap-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: all var(--duration-fast) var(--ease-out);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .swap-btn:hover {
    color: var(--color-primary);
    background: var(--bg-card-hover);
    border-color: var(--color-primary);
    transform: rotate(180deg);
  }

  .submit-btn {
    margin-top: var(--space-md);
    width: 100%;
    padding: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    background: var(--color-primary);
    color: var(--text-on-primary);
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    box-shadow: 0 4px 14px rgba(2, 132, 199, 0.3);
  }
  .submit-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(2, 132, 199, 0.4);
  }
  .submit-btn:active { transform: translateY(0); }

  .suggestions {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: var(--radius-sm);
    list-style: none;
    max-height: 220px;
    overflow-y: auto;
    z-index: 30;
    display: none;
    box-shadow: var(--shadow-lg);
    animation: slideDown var(--duration-fast) var(--ease-out);
  }
  .suggestions.active { display: block; }
  .suggestions li {
    padding: 10px 16px;
    cursor: pointer;
    color: var(--text-primary);
    font-size: var(--text-sm);
    transition: background var(--duration-fast);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .suggestions li:hover,
  .suggestions li[aria-selected="true"] {
    background: var(--color-info-bg);
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .search-inputs {
      flex-direction: column;
    }
    .input-group { min-width: 100%; }
    .swap-btn {
      transform: rotate(0deg);
    }
    .swap-btn:hover {
      transform: rotate(180deg);
    }
  }
</style>

<script define:vars={{ cities }}>
  function setupAutocomplete(inputId, listId) {
    const input = document.getElementById(inputId);
    const list = document.getElementById(listId);
    let selectedSlug = '';

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      if (q.length < 2) { list.classList.remove('active'); return; }
      const matches = cities
        .filter(c =>
          c.searchName.toLowerCase().includes(q) ||
          c.name.toLowerCase().includes(q) ||
          c.slug.includes(q)
        )
        .slice(0, 8);
      list.innerHTML = matches.map(c =>
        `<li role="option" data-slug="${c.slug}">${c.name}</li>`
      ).join('');
      list.classList.toggle('active', matches.length > 0);
    });

    list.addEventListener('click', (e) => {
      const li = e.target.closest('li');
      if (!li) return;
      selectedSlug = li.dataset.slug;
      input.value = li.textContent.trim();
      input.dataset.slug = selectedSlug;
      list.classList.remove('active');
    });

    // Handle blur and outside clicks
    document.addEventListener('click', (e) => {
      if (!e.target.closest(`#${inputId}`) && !e.target.closest(`#${listId}`)) {
        list.classList.remove('active');
      }
    });

    // Basic keyboard navigation
    input.addEventListener('keydown', (e) => {
      if (!list.classList.contains('active')) return;
      const items = Array.from(list.querySelectorAll('li'));
      if (!items.length) return;
      
      let currentIndex = items.findIndex(item => item.hasAttribute('aria-selected'));
      
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (currentIndex >= 0) items[currentIndex].removeAttribute('aria-selected');
        currentIndex = (currentIndex + 1) % items.length;
        items[currentIndex].setAttribute('aria-selected', 'true');
        input.value = items[currentIndex].textContent;
        input.dataset.slug = items[currentIndex].dataset.slug;
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (currentIndex >= 0) items[currentIndex].removeAttribute('aria-selected');
        currentIndex = currentIndex <= 0 ? items.length - 1 : currentIndex - 1;
        items[currentIndex].setAttribute('aria-selected', 'true');
        input.value = items[currentIndex].textContent;
        input.dataset.slug = items[currentIndex].dataset.slug;
      } else if (e.key === 'Enter') {
        e.preventDefault();
        list.classList.remove('active');
      }
    });
  }

  setupAutocomplete('from-input', 'from-suggestions');
  setupAutocomplete('to-input', 'to-suggestions');

  document.getElementById('swap-btn')?.addEventListener('click', () => {
    const from = document.getElementById('from-input');
    const to = document.getElementById('to-input');
    const tempVal = from.value;
    from.value = to.value;
    to.value = tempVal;
    
    const tempSlug = from.dataset.slug;
    from.dataset.slug = to.dataset.slug;
    to.dataset.slug = tempSlug;
  });

  document.getElementById('search-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const fromInput = document.getElementById('from-input');
    const toInput = document.getElementById('to-input');
    
    let from = fromInput.dataset.slug;
    let to = toInput.dataset.slug;

    // Fallback: If user typed but didn't select, try to find an exact or best match
    if (!from && fromInput.value) {
      const match = cities.find(c => c.name.toLowerCase() === fromInput.value.toLowerCase() || c.searchName.toLowerCase() === fromInput.value.toLowerCase());
      if (match) from = match.slug;
    }
    if (!to && toInput.value) {
      const match = cities.find(c => c.name.toLowerCase() === toInput.value.toLowerCase() || c.searchName.toLowerCase() === toInput.value.toLowerCase());
      if (match) to = match.slug;
    }

    if (from && to && from !== to) {
      window.location.href = `/distance/${from}-to-${to}/`;
    } else {
      alert("Please select valid and distinct cities from the dropdown.");
    }
  });
</script>
