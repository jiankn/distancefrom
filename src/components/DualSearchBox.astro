---
// Dual city search with autocomplete — upgraded UI
---
<form class="search-box animate-in" action="/distance/" method="get" id="search-form" role="search" aria-label="Distance search">
  <div class="search-inputs">
    <div class="input-group">
      <label for="from-input" class="sr-only">From city</label>
      <div class="input-wrapper">
        <svg class="input-icon icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 11.5 7.3 11.8a1 1 0 0 0 1.4 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
        <input type="text" id="from-input" name="from" placeholder="From city..." autocomplete="off" required aria-label="Origin city" />
      </div>
      <ul class="suggestions" id="from-suggestions" role="listbox" aria-label="City suggestions"></ul>
    </div>

    <button type="button" class="swap-btn" id="swap-btn" aria-label="Swap cities" tabindex="0">
      <svg class="icon-svg" viewBox="0 0 24 24"><path d="m7 16 4 4 4-4"/><path d="M11 20V4"/></svg>
    </button>

    <div class="input-group">
      <label for="to-input" class="sr-only">To city</label>
      <div class="input-wrapper">
        <svg class="input-icon icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 11.5 7.3 11.8a1 1 0 0 0 1.4 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
        <input type="text" id="to-input" name="to" placeholder="To city..." autocomplete="off" required aria-label="Destination city" />
      </div>
      <ul class="suggestions" id="to-suggestions" role="listbox" aria-label="City suggestions"></ul>
    </div>
  </div>

  <button type="submit" class="submit-btn">
    <svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="M2 12h20"/><path d="m15 5 7 7-7 7"/></svg>
    Calculate Distance
  </button>
</form>

<style>
  .search-box {
    margin: var(--space-xl) 0;
    position: relative;
    z-index: 100;
  }

  .search-inputs {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .input-group {
    flex: 1;
    min-width: 200px;
    position: relative;
  }

  .input-wrapper {
    position: relative;
  }

  .input-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-primary);
    pointer-events: none;
    width: 16px;
    height: 16px;
  }

  .input-group input {
    width: 100%;
    padding: 14px 16px 14px 40px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--text-base);
    font-family: var(--font-sans);
    outline: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-sm);
    transition: all var(--duration-fast) var(--ease-out);
  }
  .input-group input::placeholder {
    color: var(--text-muted);
  }
  .input-group input:focus {
    border-color: var(--color-primary);
    background: var(--bg-glass-strong);
    box-shadow: var(--shadow-glow);
  }

  .swap-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: all var(--duration-fast) var(--ease-out);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .swap-btn:hover {
    color: var(--color-primary);
    background: var(--bg-card-hover);
    border-color: var(--color-primary);
    transform: rotate(180deg);
  }

  .submit-btn {
    margin-top: var(--space-md);
    width: 100%;
    padding: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    background: var(--color-primary);
    color: var(--text-on-primary);
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    box-shadow: 0 4px 14px rgba(2, 132, 199, 0.3);
  }
  .submit-btn:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(2, 132, 199, 0.4);
  }
  .submit-btn:active { transform: translateY(0); }

  .suggestions {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: var(--radius-sm);
    list-style: none;
    max-height: 220px;
    overflow-y: auto;
    z-index: 50;
    display: none;
    box-shadow: var(--shadow-lg);
    animation: slideDown var(--duration-fast) var(--ease-out);
  }
  .suggestions.active { display: block; }
  .suggestions li {
    padding: 10px 16px;
    cursor: pointer;
    color: var(--text-primary);
    font-size: var(--text-sm);
    transition: background var(--duration-fast);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .suggestions li:hover,
  .suggestions li[aria-selected="true"] {
    background: var(--color-info-bg);
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .search-inputs {
      flex-direction: column;
    }
    .input-group { min-width: 100%; }
    .swap-btn {
      transform: rotate(0deg);
    }
    .swap-btn:hover {
      transform: rotate(180deg);
    }
  }
</style>

<script>
  import citiesData from '../data/cities.json';

  const cities = Object.entries(citiesData).map(([slug, c]: [string, any]) => ({
    slug, name: c.name, country: c.countryName, state: c.state,
  }));

  function setupAutocomplete(inputId: string, listId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement;
    const list = document.getElementById(listId) as HTMLUListElement;
    let selectedSlug = '';

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      if (q.length < 2) { list.classList.remove('active'); return; }
      const matches = cities
        .filter(c => c.name.toLowerCase().includes(q) || c.slug.includes(q))
        .slice(0, 8);
      list.innerHTML = matches.map(c =>
        `<li role="option" data-slug="${c.slug}">${c.name}${c.state ? ', ' + c.state : ''}, ${c.country}</li>`
      ).join('');
      list.classList.toggle('active', matches.length > 0);
    });

    list.addEventListener('click', (e) => {
      const li = (e.target as HTMLElement).closest('li');
      if (!li) return;
      selectedSlug = li.dataset.slug!;
      input.value = li.textContent!.split(',')[0];
      input.dataset.slug = selectedSlug;
      list.classList.remove('active');
    });

    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest(`#${inputId}, #${listId}`)) {
        list.classList.remove('active');
      }
    });
  }

  setupAutocomplete('from-input', 'from-suggestions');
  setupAutocomplete('to-input', 'to-suggestions');

  document.getElementById('swap-btn')?.addEventListener('click', () => {
    const from = document.getElementById('from-input') as HTMLInputElement;
    const to = document.getElementById('to-input') as HTMLInputElement;
    [from.value, to.value] = [to.value, from.value];
    [from.dataset.slug, to.dataset.slug] = [to.dataset.slug, from.dataset.slug];
  });

  document.getElementById('search-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const from = (document.getElementById('from-input') as HTMLInputElement).dataset.slug;
    const to = (document.getElementById('to-input') as HTMLInputElement).dataset.slug;
    if (from && to && from !== to) {
      window.location.href = `/distance/${from}-to-${to}/`;
    }
  });
</script>
