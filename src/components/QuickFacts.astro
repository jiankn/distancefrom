---
interface CityFact {
  name: string;
  lat: number;
  lng: number;
  timezone: string;
  elevation: number;
}
interface Props { cityA: CityFact; cityB: CityFact; }
const { cityA, cityB } = Astro.props;

function formatCoord(lat: number, lng: number): string {
  const latDir = lat >= 0 ? 'N' : 'S';
  const lngDir = lng >= 0 ? 'E' : 'W';
  return `${Math.abs(lat).toFixed(2)}°${latDir}, ${Math.abs(lng).toFixed(2)}°${lngDir}`;
}
---
<section class="card--flat facts-section animate-in animate-in-delay-3">
  <div class="facts-header">
    <div class="section-icon" style="--icon-bg: rgba(14, 165, 233, 0.1); --icon-color: #0ea5e9;">
      <svg class="icon-svg" viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
    </div>
    <h2>Quick Facts</h2>
  </div>

  <div class="facts-grid">
    <!-- City A -->
    <div class="fact-card">
      <div class="fact-city-name">{cityA.name}</div>
      <div class="fact-details">
        <div class="fact-item">
          <svg class="icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 11.5 7.3 11.8a1 1 0 0 0 1.4 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
          <span>{formatCoord(cityA.lat, cityA.lng)}</span>
        </div>
        <div class="fact-item">
          <svg class="icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <span>{cityA.timezone}</span>
        </div>
        <div class="fact-item">
          <svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="m2 22 1-1h3l9-9"/><path d="M3 21v-3l9-9"/><path d="m15 6 3.4-3.4a2.1 2.1 0 1 1 3 3L18 9l.4.4a2.1 2.1 0 1 1-3 3l-3.8-3.8a2.1 2.1 0 1 1 3-3l.4.4z"/></svg>
          <span>{cityA.elevation}m elevation</span>
        </div>
      </div>
    </div>

    <!-- City B -->
    <div class="fact-card">
      <div class="fact-city-name">{cityB.name}</div>
      <div class="fact-details">
        <div class="fact-item">
          <svg class="icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 11.5 7.3 11.8a1 1 0 0 0 1.4 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
          <span>{formatCoord(cityB.lat, cityB.lng)}</span>
        </div>
        <div class="fact-item">
          <svg class="icon-svg--sm" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <span>{cityB.timezone}</span>
        </div>
        <div class="fact-item">
          <svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="m2 22 1-1h3l9-9"/><path d="M3 21v-3l9-9"/><path d="m15 6 3.4-3.4a2.1 2.1 0 1 1 3 3L18 9l.4.4a2.1 2.1 0 1 1-3 3l-3.8-3.8a2.1 2.1 0 1 1 3-3l.4.4z"/></svg>
          <span>{cityB.elevation}m elevation</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .facts-section { margin: var(--space-lg) 0; padding: 0; overflow: hidden; }

  .facts-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }
  .facts-header h2 {
    font-size: var(--text-lg);
    color: var(--text-primary);
  }

  .section-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    background: var(--icon-bg);
    color: var(--icon-color);
    flex-shrink: 0;
  }

  .facts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .fact-card {
    padding: var(--space-lg);
    transition: background var(--duration-fast);
  }
  .fact-card:first-child {
    border-right: 1px solid var(--border);
  }
  .fact-card:hover { background: rgba(255, 255, 255, 0.3); }

  .fact-city-name {
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }

  .fact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .fact-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .fact-item .icon-svg--sm { color: var(--color-primary); }

  @media (max-width: 640px) {
    .facts-grid { grid-template-columns: 1fr; }
    .fact-card:first-child {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
  }
</style>
