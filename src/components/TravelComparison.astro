---
interface Props {
  cityA: string;
  cityB: string;
  drivable: boolean;
  driveTime: string;
  driveMiles: number;
  driveMinutes: number;
  fuelCost: string;
  flightTime: string;
  noDirectFlight: boolean;
  straightLineKm: number;
}
const { cityA, cityB, drivable, driveTime, driveMiles, driveMinutes, fuelCost, flightTime, noDirectFlight, straightLineKm } = Astro.props;

const busMinutes = Math.round(driveMinutes * 1.2);
const busH = Math.floor(busMinutes / 60);
const busM = busMinutes % 60;
const busTime = busH > 0 ? `${busH}h ${busM}min` : `${busM}min`;
const busCostLow = Math.round(driveMiles * 0.08);
const busCostHigh = Math.round(driveMiles * 0.15);

const trainFactor = straightLineKm < 800 ? 0.95 : 1.3;
const trainMinutes = Math.round(driveMinutes * trainFactor);
const trainH = Math.floor(trainMinutes / 60);
const trainM = trainMinutes % 60;
const trainTime = trainH > 0 ? `${trainH}h ${trainM}min` : `${trainM}min`;
const trainCostLow = Math.round(driveMiles * 0.12);
const trainCostHigh = Math.round(driveMiles * 0.35);

let verdict = '';
if (!drivable) {
  verdict = `A standard driving route may not be practical between ${cityA} and ${cityB}; compare flights and local transit before planning.`;
} else if (driveMiles < 150) {
  verdict = `At ${driveMiles} miles, driving is often the most practical option.`;
} else if (driveMiles < 400) {
  verdict = `For 2+ travelers, driving is usually cheaper. Solo? Consider the bus.`;
} else {
  verdict = `Flying saves significant time. Driving is better if you want flexibility and stops.`;
}
---
<section class="card--flat comparison-section animate-in">
  <div class="comparison-header">
    <div class="section-icon" style="--icon-bg: rgba(139, 92, 246, 0.1); --icon-color: #8b5cf6;">
      <svg class="icon-svg" viewBox="0 0 24 24"><path d="M8 6h13"/><path d="M8 12h13"/><path d="M8 18h13"/><path d="M3 6h.01"/><path d="M3 12h.01"/><path d="M3 18h.01"/></svg>
    </div>
    <h2>How to Get from {cityA} to {cityB}</h2>
  </div>
  <div class="comparison-table">
    <div class="ct-header">
      <span class="ct-col ct-method">Method</span>
      <span class="ct-col">Time</span>
      <span class="ct-col">Est. Cost</span>
      <span class="ct-col ct-best">Best For</span>
    </div>
    {drivable && (
      <div class="ct-row">
        <span class="ct-col ct-method"><svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-2-2.2-3.3C13 5.6 11.7 5 10 5H5c-1.3 0-2.5.7-3.2 1.7L.5 9H2l1 3h1"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg> Drive</span>
        <span class="ct-col">{driveTime}</span>
        <span class="ct-col">{fuelCost}</span>
        <span class="ct-col ct-best">Flexible stops</span>
      </div>
    )}
    {!noDirectFlight && (
      <div class="ct-row">
        <span class="ct-col ct-method"><svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg> Fly</span>
        <span class="ct-col">~{flightTime}</span>
        <span class="ct-col">$80–200*</span>
        <span class="ct-col ct-best">Speed</span>
      </div>
    )}
    {drivable && driveMiles > 50 && (
      <div class="ct-row">
        <span class="ct-col ct-method"><svg class="icon-svg--sm" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg> Bus</span>
        <span class="ct-col">~{busTime}</span>
        <span class="ct-col">${busCostLow}–${busCostHigh}*</span>
        <span class="ct-col ct-best">Budget</span>
      </div>
    )}
    {drivable && driveMiles > 80 && (
      <div class="ct-row">
        <span class="ct-col ct-method"><svg class="icon-svg--sm" viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg> Train</span>
        <span class="ct-col">~{trainTime}</span>
        <span class="ct-col">${trainCostLow}–${trainCostHigh}*</span>
        <span class="ct-col ct-best">Comfort</span>
      </div>
    )}
  </div>
  <div class="ct-footer">
    <p class="ct-verdict"><svg class="icon-svg--sm" viewBox="0 0 24 24" style="color: var(--color-cta);"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg> {verdict}</p>
    <p class="ct-note">* Estimated range. Actual prices vary by date and provider.</p>
  </div>
</section>

<style>
  .comparison-section { margin: var(--space-lg) 0; padding: 0; overflow: hidden; }
  .comparison-header {
    display: flex; align-items: center; gap: var(--space-md);
    padding: var(--space-lg); border-bottom: 1px solid var(--border);
  }
  .comparison-header h2 { font-size: var(--text-lg); color: var(--text-primary); margin: 0; }
  .section-icon {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: var(--radius-sm);
    background: var(--icon-bg); color: var(--icon-color); flex-shrink: 0;
  }
  .comparison-table { width: 100%; }
  .ct-header {
    display: flex; padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-xs); font-weight: 600; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.04em;
    border-bottom: 1px solid var(--border);
  }
  .ct-row {
    display: flex; padding: var(--space-md) var(--space-lg);
    font-size: var(--text-sm); color: var(--text-primary);
    transition: background var(--duration-fast);
  }
  .ct-row:hover { background: rgba(255,255,255,0.3); }
  .ct-row + .ct-row { border-top: 1px solid var(--border); }
  .ct-col { flex: 1; display: flex; align-items: center; gap: 6px; }
  .ct-method { font-weight: 500; flex: 0.8; }
  .ct-best { color: var(--text-muted); flex: 1.2; }
  .ct-footer { padding: var(--space-md) var(--space-lg); border-top: 1px solid var(--border); }
  .ct-verdict {
    display: flex; align-items: center; gap: 6px;
    font-size: var(--text-sm); font-weight: 500; color: var(--text-secondary);
  }
  .ct-note { font-size: var(--text-xs); color: var(--text-muted); margin-top: 4px; }
  @media (max-width: 640px) {
    .ct-best { display: none; }
    .ct-header, .ct-row { padding: var(--space-sm) var(--space-md); }
  }
</style>
