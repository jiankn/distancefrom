---
interface Props {
  cityA: { name: string; state?: string; countryName: string; type?: string };
  cityB: { name: string; state?: string; countryName: string; type?: string };
  straightLineMiles: number;
  straightLineKm: number;
  drivable: boolean;
  driveMiles: number;
  driveTime: string;
  driveSource: 'osrm' | 'estimated';
  flightTime: string;
  bearingDir: string;
}
const { cityA, cityB, straightLineMiles, straightLineKm, drivable, driveMiles, driveTime, driveSource, flightTime, bearingDir } = Astro.props;

const locA = cityA.state ? `${cityA.state}, ${cityA.countryName}` : cityA.countryName;
const locB = cityB.state ? `${cityB.state}, ${cityB.countryName}` : cityB.countryName;
const isNP = cityB.type === 'national-park' || cityA.type === 'national-park';

let paragraphs: string[] = [];

let p1 = `The distance from ${cityA.name} to ${cityB.name} is ${straightLineMiles} miles (${straightLineKm} km) as the crow flies. `;
p1 += `${cityB.name} is located ${bearingDir} of ${cityA.name}. `;

if (drivable && driveMiles > 0) {
  p1 += `By car, the driving distance is approximately ${driveMiles} miles, taking about ${driveTime}. `;
}
p1 += `A direct flight would take roughly ${flightTime}. `;

if (cityA.countryName === cityB.countryName) {
  p1 += `Both are located in ${cityA.countryName}`;
  if (cityA.state && cityB.state && cityA.state !== cityB.state) {
    p1 += ` — ${cityA.name} in ${cityA.state} and ${cityB.name} in ${cityB.state}`;
  }
  p1 += '.';
} else {
  p1 += `${cityA.name} is in ${locA}, while ${cityB.name} is in ${locB}.`;
}
paragraphs.push(p1.trim());

// Micro-differentiators for SEO and UX
if (drivable && driveMiles > 0) {
  let travelAdvice = "";
  
  // 1. Fatigue & Rest Stop Advice based on distance
  if (driveMiles < 50) {
    travelAdvice += "This is a very short trip, perfect for a quick morning drive or an easy commute. ";
  } else if (driveMiles >= 50 && driveMiles < 120) {
    travelAdvice += "This is a quick and easy drive, perfect for a day trip or weekend getaway. You can easily make the round trip in a single day. ";
  } else if (driveMiles >= 120 && driveMiles <= 360) {
    travelAdvice += "For a drive of this length, it's recommended to plan at least one quick rest stop to stretch your legs and grab a coffee. ";
  } else if (driveMiles > 360 && driveMiles <= 600) {
    travelAdvice += "This is a solid day of driving. Be sure to take breaks every 2-3 hours to avoid driver fatigue, and plan your meals ahead of time. ";
  } else if (driveMiles > 600) {
    travelAdvice += "This is a serious multi-day road trip! We strongly recommend breaking this journey up with an overnight stay to ensure you arrive safely and refreshed. ";
  }

  // 2. Directional / Environmental Tips
  if (bearingDir.includes("W")) {
    travelAdvice += "Since you'll be heading mostly West, pack a good pair of sunglasses if you plan to drive during the late afternoon to avoid the harsh sun glare. ";
  } else if (bearingDir.includes("E")) {
    travelAdvice += "Heading East means you'll be driving into the sunrise if you start early. Keep your windshield clean for the best visibility. ";
  } else if (bearingDir.includes("N") && driveMiles > 400) {
    travelAdvice += "Heading North for this distance usually means noticeable weather changes. Make sure to check the forecast for your destination before hitting the road. ";
  } else if (bearingDir.includes("S") && driveMiles > 400) {
    travelAdvice += "As you head South, expect warmer temperatures. Make sure your car's AC is working well before embarking on this journey. ";
  }

  // 3. Cross-border Tips
  if (cityA.countryName !== cityB.countryName) {
    travelAdvice += "Keep in mind this route crosses international borders. Don't forget your passport, and check current border crossing times and vehicle insurance requirements. ";
  }

  // 4. Flight vs Drive practical comparison
  if (driveMiles < 250) {
    travelAdvice += "Given the short distance, driving or taking a train is often faster and more convenient than dealing with airport security and flight boarding times. ";
  } else if (driveMiles > 800) {
    travelAdvice += "For a trip of this distance, flying is significantly faster. However, driving offers the flexibility to explore stops along the way. ";
  }
  
  if (travelAdvice) {
    paragraphs.push(travelAdvice.trim());
  }
}

const confidenceParts = [
  `Coordinates come from public place data for ${cityA.name} and ${cityB.name}.`,
  drivable && driveMiles > 0
    ? driveSource === 'osrm'
      ? 'The driving distance uses an OSRM road-route result when route data is available.'
      : 'The driving distance is estimated from straight-line distance with a road-factor model, so confirm the route in your navigation app.'
    : 'No practical driving route is shown, so the page emphasizes straight-line distance and flight-time context.',
  'Fuel, flight, bus, and train values are planning estimates and can change by date, provider, road closures, and border rules.',
];
paragraphs.push(confidenceParts.join(' '));
---
<section class="natural-desc animate-in">
  <h2 class="sr-only">How far is {cityA.name} from {cityB.name}?</h2>
  {paragraphs.map(p => <p>{p}</p>)}
</section>

<style>
  .natural-desc {
    margin: var(--space-md) 0 var(--space-lg);
    padding: var(--space-lg);
    background: var(--bg-glass);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .natural-desc p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }
  .natural-desc p + p {
    margin-top: 0.75rem;
  }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
</style>
