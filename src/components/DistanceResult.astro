---
interface Props {
  straightLineMiles: number;
  straightLineKm: number;
  drivingMiles: number;
  drivingKm: number;
  driveTime: string;
  driveSource: 'osrm' | 'estimated';
  drivable: boolean;
  flightTime: string;
  noDirectFlight: boolean;
  bearingDeg: number;
  bearingDir: string;
  fuelCost: string;
}
const {
  straightLineMiles, straightLineKm,
  drivingMiles, drivingKm, driveTime, driveSource, drivable,
  flightTime, noDirectFlight,
  bearingDeg, bearingDir, fuelCost,
} = Astro.props;
---
<div class="card--flat result-card animate-in">
  <!-- Straight Line -->
  <div class="result-row">
    <div class="result-icon" style="--icon-bg: var(--color-info-bg); --icon-color: var(--color-info);">
      <svg class="icon-svg" viewBox="0 0 24 24"><path d="M2 12h20"/><path d="m15 5 7 7-7 7"/></svg>
    </div>
    <div class="result-data">
      <span class="result-value">{straightLineMiles} <small>miles</small></span>
      <span class="result-sub">{straightLineKm} km &middot; straight line</span>
    </div>
  </div>

  {drivable ? (
    <>
      <!-- Driving Distance -->
      <div class="result-row">
        <div class="result-icon" style="--icon-bg: var(--color-success-bg); --icon-color: var(--color-success);">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-2-2.2-3.3C13 5.6 11.7 5 10 5H5c-1.3 0-2.5.7-3.2 1.7L.5 9H2l1 3h1"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
        </div>
        <div class="result-data">
          <span class="result-value">{drivingMiles} <small>miles</small>
            <span class:list={['badge', driveSource === 'osrm' ? 'badge--success' : 'badge--warning']}>
              {driveSource === 'osrm' ? 'actual route' : 'estimated'}
            </span>
          </span>
          <span class="result-sub">{drivingKm} km &middot; driving distance</span>
        </div>
      </div>

      <!-- Drive Time -->
      <div class="result-row">
        <div class="result-icon" style="--icon-bg: rgba(139, 92, 246, 0.1); --icon-color: #8b5cf6;">
          <svg class="icon-svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <div class="result-data">
          <span class="result-value">{driveTime}</span>
          <span class="result-sub">estimated drive time</span>
        </div>
      </div>

      <!-- Fuel Cost -->
      <div class="result-row">
        <div class="result-icon" style="--icon-bg: rgba(245, 158, 11, 0.1); --icon-color: #f59e0b;">
          <svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="result-data">
          <span class="result-value">{fuelCost}</span>
          <span class="result-sub">estimated fuel cost</span>
        </div>
      </div>
    </>
  ) : (
    <div class="result-row">
      <div class="result-icon" style="--icon-bg: var(--color-warning-bg); --icon-color: var(--color-warning);">
        <svg class="icon-svg" viewBox="0 0 24 24"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-2-2.2-3.3C13 5.6 11.7 5 10 5H5c-1.3 0-2.5.7-3.2 1.7L.5 9H2l1 3h1"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
      </div>
      <div class="result-data">
        <span class="result-value muted-val">Not drivable</span>
        <span class="result-sub">ocean or continent separation</span>
      </div>
    </div>
  )}

  <!-- Flight -->
  <div class="result-row">
    <div class="result-icon" style="--icon-bg: rgba(59, 130, 246, 0.1); --icon-color: #3b82f6;">
      <svg class="icon-svg" viewBox="0 0 24 24"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
    </div>
    <div class="result-data">
      <span class="result-value">~{flightTime}</span>
      <span class="result-sub">flight time{noDirectFlight ? ' · usually no direct flights' : ''}</span>
    </div>
  </div>

  <!-- Bearing -->
  <div class="result-row">
    <div class="result-icon" style="--icon-bg: rgba(14, 165, 233, 0.1); --icon-color: #0ea5e9;">
      <svg class="icon-svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m16.24 7.76-2.12 6.36-6.36 2.12 2.12-6.36 6.36-2.12z"/></svg>
    </div>
    <div class="result-data">
      <span class="result-value">{bearingDeg}° <small>{bearingDir}</small></span>
      <span class="result-sub">bearing direction</span>
    </div>
  </div>
</div>

<style>
  .result-card {
    margin: var(--space-lg) 0;
    padding: 0;
    overflow: hidden;
  }

  .result-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    transition: background var(--duration-fast) var(--ease-out);
  }
  .result-row:hover {
    background: rgba(255, 255, 255, 0.3);
  }
  .result-row + .result-row {
    border-top: 1px solid var(--border);
  }

  .result-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--icon-bg);
    color: var(--icon-color);
    flex-shrink: 0;
  }

  .result-data {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .result-value {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .result-value small {
    font-weight: 400;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .result-sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .muted-val {
    color: var(--text-muted);
    font-style: italic;
  }

  @media (max-width: 480px) {
    .result-row { padding: var(--space-sm) var(--space-md); }
    .result-icon { width: 34px; height: 34px; }
    .result-value { font-size: var(--text-base); }
  }
</style>
