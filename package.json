{
  "name": "distancefrom",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "data:cities": "tsx scripts/prepare-cities.ts",
    "data:routes": "tsx scripts/fetch-osrm-routes.ts",
    "data:pairs": "tsx scripts/generate-popular-pairs.ts",
    "data:split-routes": "tsx scripts/split-route-data.ts",
    "data:all": "npm run data:cities && npm run data:pairs",
    "deploy": "npm run data:split-routes && npm run build && npx wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.3",
    "astro": "^6.0.8"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
