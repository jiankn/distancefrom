# MapTiler API Key (free: 100K req/month)
# https://cloud.maptiler.com/account/keys/
PUBLIC_MAPTILER_KEY=

# Stadia Maps API Key (free tier available, required for production)
# https://client.stadiamaps.com/
PUBLIC_STADIA_KEY=

# No key needed for CARTO and OSM (auto-fallback)
# Fallback order: MapTiler → Stadia → CARTO → OSM
